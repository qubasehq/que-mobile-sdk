# Exclude all top-level hidden directories by convention
/.*/

# Exclude tarballs generated by `npm pack`
/*.tgz

# Tests
__mocks__
__tests__
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
coverage/

# Config files
/babel.config.js
/jest.config.js
/jest.setup.js
/.eslintrc.js
/tsconfig.json

# Android test files
/android/src/androidTest/
/android/src/test/
/android/build/

# iOS test files
/ios/Tests/

# Example app
/example/

# Source files (only ship compiled)
/src/

# Documentation
/docs/

# CI/CD
/.github/
/.circleci/

# Development
.vscode/
.idea/
*.log
.DS_Store

# Keep only build output
!build/
